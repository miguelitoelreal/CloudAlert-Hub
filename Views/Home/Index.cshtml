@{
    ViewData["Title"] = "Estado Global: Operativo";
}

<div class="dashboard-content">
    <!-- Filtros -->
    <aside class="filters">
        <h3>Proveedores Cloud</h3>
        <ul>
            <li><input type="checkbox" checked /> Todos</li>
            <li><input type="checkbox" /> Azure</li>
            <li><input type="checkbox" /> AWS</li>
            <li><input type="checkbox" /> Microsoft 365</li>
        </ul>

        <h3>Filtro de Severidad</h3>
        <ul>
            <li><input type="radio" name="severity" /> Crítico (P0) <span style="color: #ef4444;">2</span></li>
            <li><input type="radio" name="severity" /> Mayor (P1) <span style="color: #f59e0b;">5</span></li>
            <li><input type="radio" name="severity" /> Menor (P2) <span style="color: #10b981;">12</span></li>
        </ul>
        <button class="reset-filters">Restablecer Filtros</button>
    </aside>

    <!-- Tabla de Incidentes -->
    <section class="incidents">
        <h2>Incidentes Activos</h2>
        <p>Monitoreo de disponibilidad en tiempo real.</p>

        <table class="incidents-table">
            <thead>
                <tr>
                    <th>Proveedor</th>
                    <th>Servicio Afectado</th>
                    <th>Severidad</th>
                    <th>Duración</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>🔵 Azure</td>
                    <td>Base de Datos SQL (East US)</td>
                    <td class="critical">CRÍTICO</td>
                    <td>02:14:45</td>
                    <td><a href="#">Ver Detalles</a></td>
                </tr>
                <tr>
                    <td>🟠 AWS</td>
                    <td>Almacenamiento S3</td>
                    <td class="major">MAYOR</td>
                    <td>00:45:12</td>
                    <td><a href="#">Ver Detalles</a></td>
                </tr>
                <tr>
                    <td>🟢 Microsoft 365</td>
                    <td>Exchange Online Sync</td>
                    <td class="minor">MENOR</td>
                    <td>05:22:19</td>
                    <td><a href="#">Ver Detalles</a></td>
                </tr>
                <tr>
                    <td>🔵 Azure</td>
                    <td>Autenticación AD</td>
                    <td class="major">MAYOR</td>
                    <td>00:12:39</td>
                    <td><a href="#">Ver Detalles</a></td>
                </tr>
            </tbody>
        </table>
        <p style="margin-top: 24px; color: #64748b; font-size: 12px;">Mostrando 4 de 10 incidentes activos</p>
    </section>
</div>

