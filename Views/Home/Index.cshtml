@{
    ViewData["Title"] = "Estado de Servicios";
}

<div class="services-container">
    <h1 class="services-title">Estado de Servicios</h1>
    
    <div class="services-grid">
        <!-- EC2 Instances -->
        <div class="service-card">
            <div class="service-header">
                <div class="service-icon">☁️</div>
                <div class="service-name">
                    <h3>EC2 Instances</h3>
                    <p class="service-provider">AWS</p>
                </div>
                <span class="status-badge status-active">Activo</span>
            </div>
            <div class="service-body">
                <div class="availability-item">
                    <label>Disponibilidad</label>
                    <div class="progress-container">
                        <div class="progress-bar" style="width: 99.99%; background-color: #10b981;"></div>
                        <span class="percentage">99.99%</span>
                    </div>
                </div>
                <p class="last-check">Última comprobación: hace 9 min</p>
            </div>
        </div>

        <!-- RDS Database -->
        <div class="service-card">
            <div class="service-header">
                <div class="service-icon">🗄️</div>
                <div class="service-name">
                    <h3>RDS Database</h3>
                    <p class="service-provider">AWS</p>
                </div>
                <span class="status-badge status-warning">Advertencia</span>
            </div>
            <div class="service-body">
                <div class="availability-item">
                    <label>Disponibilidad</label>
                    <div class="progress-container">
                        <div class="progress-bar" style="width: 99.85%; background-color: #f59e0b;"></div>
                        <span class="percentage">99.85%</span>
                    </div>
                </div>
                <p class="last-check">Última comprobación: hace 2 min</p>
            </div>
        </div>

        <!-- Lambda Functions -->
